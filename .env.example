# =============================================================
# Smart Daily Assistant — environment variables
# Copy this file to .env.local for local dev. Never commit .env.local.
# In production, set these in your Vercel project's Environment Variables.
# =============================================================

# --- OpenRouter (LLM provider) ---
# Get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Model slug from https://openrouter.ai/models
# Default: google/gemini-2.0-flash-001
# Other good picks:
#   google/gemini-2.5-flash-preview-09-2025
#   google/gemini-flash-1.5
#   anthropic/claude-3.5-haiku
#   openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Optional. Override the OpenRouter base URL (defaults to https://openrouter.ai/api/v1).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional but recommended — improves model leaderboard attribution.
OPENROUTER_SITE_NAME=Smart Daily Assistant
OPENROUTER_SITE_URL=https://your-app.vercel.app

# --- Telegram Bot ---
# Created via https://t.me/BotFather (/newbot). Token format: 1234567890:ABCDEF...
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional but recommended. Random secret to verify Telegram webhook calls.
# Generate with: openssl rand -hex 24
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret

# --- App URL ---
# Public base URL of your deployment (no trailing slash). Used by the
# webhook setup script. Vercel sets VERCEL_URL automatically in prod.
APP_URL=https://your-app.vercel.app
